# Copy to .env and fill in. Never commit .env.

# --- Zernio (https://zernio.com/dashboard/api-keys) ---
ZERNIO_API_KEY=

# --- Dropbox ---
# Option A (simplest, expires every ~4h — fine for testing):
DROPBOX_ACCESS_TOKEN=
# Option B (recommended for daily automation — long-lived):
# Create an app at https://www.dropbox.com/developers/apps with files.content.read/write
# (+ sharing.write for permanent links), then run the one-time OAuth flow to get a refresh token:
#   node scripts/dropbox-auth.mjs url     # open the URL, approve, copy the code
#   node scripts/dropbox-auth.mjs <code>  # prints DROPBOX_REFRESH_TOKEN
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=

# Dropbox folder layout (paths inside your Dropbox)
DROPBOX_RAW_FOLDER=/vault/raw
DROPBOX_EDITED_FOLDER=/vault/edited

# Default timezone for scheduled posts (IANA name, e.g. UTC, America/New_York, Europe/London).
# Overridable per-call with `--tz`. Falls back to UTC if unset.
TIMEZONE=UTC

# --- Local tools (optional overrides) ---
# whisper.cpp binary + model for transcription (scripts/analyze-video.mjs).
# Defaults: WHISPER_BIN=whisper-cli, WHISPER_MODEL=models/ggml-small.en.bin
# WHISPER_BIN=whisper-cli
# WHISPER_MODEL=models/ggml-small.en.bin
